# Mode-B tailnet consent drop-in — generated by scripts/mode-b-setup.sh
# Realm: __REALM__   Agent: __AGENT__
# Network membership (the tailnet/WireGuard) IS the consent gate: an authenticated
# tailnet peer is DELIVER; only an explicitly BLOCKED sender is DROP.
# This is additive + opt-in — consent stays OFF until this env var is present.
[Service]
Environment=SKCOMMS_CONSENT_MODE=__CONSENT_MODE__
