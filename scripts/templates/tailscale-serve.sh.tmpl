#!/usr/bin/env bash
# Mode-B tailnet exposure — generated by scripts/mode-b-setup.sh.
# Uses `tailscale serve` (tailnet-only) NOT `tailscale funnel` (public). The inbox
# + skfed directory become reachable only by authenticated tailnet members; there
# is no public attack surface. Re-running is idempotent (serve state is a set).
set -euo pipefail
tailscale serve --bg --https=443 --set-path=/api/v1/inbox                __LOCAL_BASE__/api/v1/inbox
tailscale serve --bg --https=443 --set-path=/.well-known/skfed/directory __LOCAL_BASE__/.well-known/skfed/directory
